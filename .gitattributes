# Set default behavior to automatically normalize line endings.
* text=auto

# binary files to track with LFS
*.shp filter=lfs diff=lfs merge=lfs -text
*.dbf filter=lfs diff=lfs merge=lfs -text
*.shx filter=lfs diff=lfs merge=lfs -text
*.tif filter=lfs diff=lfs merge=lfs -text
*.pdf filter=lfs diff=lfs merge=lfs -text
*.gdb filter=lfs diff=lfs merge=lfs -text
*.png filter=lfs diff=lfs merge=lfs -text
*.nc filter=lfs diff=lfs merge=lfs -text
*.cbc filter=lfs diff=lfs merge=lfs -text
*.hds filter=lfs diff=lfs merge=lfs -text
*.bin filter=lfs diff=lfs merge=lfs -text
*.grb filter=lfs diff=lfs merge=lfs -text
*.zip filter=lfs diff=lfs merge=lfs -text
*.tar filter=lfs diff=lfs merge=lfs -text

# text files to track with LFS
*.dat filter=lfs diff=lfs merge=lfs text
*.ref filter=lfs diff=lfs merge=lfs text
*.asc filter=lfs diff=lfs merge=lfs text
*.csv filter=lfs diff=lfs merge=lfs text
*.list filter=lfs diff=lfs merge=lfs text
*.lst filter=lfs diff=lfs merge=lfs text
*.rei filter=lfs diff=lfs merge=lfs text
*.head.obs filter=lfs diff=lfs merge=lfs text
*.ins filter=lfs diff=lfs merge=lfs text
*.tpl filter=lfs diff=lfs merge=lfs text
*.fac filter=lfs diff=lfs merge=lfs text
*.zone filter=lfs diff=lfs merge=lfs text
